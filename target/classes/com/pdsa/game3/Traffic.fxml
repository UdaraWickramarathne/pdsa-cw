<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.canvas.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.pdsa.game3.ui.TrafficController"
      spacing="10" style="-fx-background-color: #1a1a2e; -fx-padding: 16;">

    <Text text="Traffic Simulation — Max Flow" style="-fx-fill: #e94560; -fx-font-size: 22; -fx-font-weight: bold;"/>

    <!-- Graph canvas -->
    <Canvas fx:id="graphCanvas" width="760" height="320"
            style="-fx-border-color: #333355; -fx-border-width: 1;"/>

    <Label text="Green = Source (A)   |   Red = Sink (T)   |   Edge labels = capacity (vehicles/min)"
           style="-fx-text-fill: #a8a8b3; -fx-font-size: 11;"/>

    <!-- Algorithm timings -->
    <HBox spacing="30">
        <Label fx:id="lblFF" text="Ford-Fulkerson: —" style="-fx-text-fill: #4ecca3; -fx-font-weight: bold;"/>
        <Label fx:id="lblEK" text="Edmonds-Karp:   —" style="-fx-text-fill: #f9a826; -fx-font-weight: bold;"/>
    </HBox>

    <Label fx:id="lblRoundInfo" text="" style="-fx-text-fill: #a8a8b3;"/>

    <!-- Player input -->
    <HBox spacing="12" alignment="CENTER_LEFT">
        <Label text="Your Name:" style="-fx-text-fill: #a8a8b3;"/>
        <TextField fx:id="tfPlayerName" promptText="Enter your name" prefWidth="160"
                   style="-fx-control-inner-background: #16213e; -fx-text-fill: #e0e0e0;"/>
        <Label text="Max Flow Answer:" style="-fx-text-fill: #a8a8b3;"/>
        <TextField fx:id="tfAnswer" promptText="Enter number" prefWidth="100"
                   style="-fx-control-inner-background: #16213e; -fx-text-fill: #e0e0e0;"/>
        <Button fx:id="btnSubmit" text="Submit" onAction="#submitAnswer"
                style="-fx-background-color: #4ecca3; -fx-text-fill: #1a1a2e; -fx-font-weight: bold; -fx-cursor: hand;"/>
        <Button text="New Round" onAction="#startNewRound"
                style="-fx-background-color: #e94560; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;"/>
    </HBox>

    <Label fx:id="lblResult" text="" wrapText="true"/>
</VBox>
