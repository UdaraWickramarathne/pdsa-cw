<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.canvas.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.*?>

<HBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.pdsa.game5.ui.SixteenQueensController"
      spacing="16" style="-fx-background-color: #1a1a2e; -fx-padding: 16;">

    <!-- Left: chessboard -->
    <VBox spacing="8" minWidth="420">
        <Text text="Sixteen Queens Puzzle" style="-fx-fill: #e94560; -fx-font-size: 22; -fx-font-weight: bold;"/>
        <Canvas fx:id="boardCanvas" width="400" height="400"/>
        <Label text="Place 16 queens so none threaten each other."
               style="-fx-text-fill: #a8a8b3; -fx-font-size: 11;"/>
    </VBox>

    <!-- Right: controls -->
    <VBox spacing="10" HBox.hgrow="ALWAYS">
        <Text text="Controls" style="-fx-fill: #4ecca3; -fx-font-size: 16; -fx-font-weight: bold;"/>

        <!-- Timing info -->
        <Label fx:id="lblTiming" text="Timing: not yet computed."
               style="-fx-text-fill: #f9a826;" wrapText="true"/>
        <Label fx:id="lblUnclaimed" text="Unclaimed: —"
               style="-fx-text-fill: #a8a8b3;"/>

        <Separator/>

        <!-- Precompute -->
        <Label text="Step 1 — Precompute all solutions (run once):"
               style="-fx-text-fill: #a8a8b3; -fx-font-size: 11;"/>
        <Button fx:id="btnPrecompute" text="Precompute All Solutions" onAction="#precompute"
                prefWidth="220"
                style="-fx-background-color: #555577; -fx-text-fill: white; -fx-cursor: hand;"/>
        <Label fx:id="lblStatus" text="Check DB status above." style="-fx-text-fill: #a8a8b3;" wrapText="true"/>

        <Separator/>

        <!-- Player input -->
        <Label text="Step 2 — Enter a valid 16-queens solution:"
               style="-fx-text-fill: #a8a8b3; -fx-font-size: 11;"/>
        <Label text="Enter 16 row numbers (1–16), one per column, space-separated."
               style="-fx-text-fill: #555577; -fx-font-size: 10;" wrapText="true"/>

        <Label text="Your Name:" style="-fx-text-fill: #a8a8b3;"/>
        <TextField fx:id="tfPlayerName" promptText="Enter your name"
                   style="-fx-control-inner-background: #16213e; -fx-text-fill: #e0e0e0;"/>

        <Label text="Queen placement (row per column):" style="-fx-text-fill: #a8a8b3;"/>
        <TextField fx:id="tfPlacement"
                   promptText="e.g.  1 3 5 8 10 12 14 16 2 4 6 9 11 13 15 7"
                   style="-fx-control-inner-background: #16213e; -fx-text-fill: #e0e0e0;"/>

        <HBox spacing="10">
            <Button fx:id="btnPlaceOnBoard" text="Preview on Board" onAction="#placeOnBoard"
                    style="-fx-background-color: #555577; -fx-text-fill: white; -fx-cursor: hand;"/>
            <Button fx:id="btnSubmit" text="Submit Answer" onAction="#submitAnswer"
                    style="-fx-background-color: #4ecca3; -fx-text-fill: #1a1a2e; -fx-font-weight: bold; -fx-cursor: hand;"/>
        </HBox>

        <Label fx:id="lblResult" text="" wrapText="true"
               style="-fx-font-size: 13; -fx-font-weight: bold;"/>
    </VBox>
</HBox>
