<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:id="root"
      fx:controller="com.pdsa.MainMenuController"
      styleClass="game-root"
      alignment="CENTER" spacing="0"
      style="-fx-padding: 0;">

    <!-- Marquee header -->
    <VBox alignment="CENTER" spacing="6"
          style="-fx-padding: 32 40 24 40; -fx-background-color: #160032;
                 -fx-border-width: 0 0 1 0; -fx-border-color: #FF2E8873;">
        <Text text="PDSA ★ ARCADE" styleClass="marquee-title"/>
        <Text text="FIVE ALGORITHMS · FIVE CABINETS · ONE LEADERBOARD" styleClass="marquee-sub"/>
        <Label text="BSc (Hons) Computing 25.2 · NIBM" styleClass="ui-caption" style="-fx-padding: 4 0 0 0;"/>
    </VBox>

    <!-- Error banner slot -->
    <HBox fx:id="bannerBox" styleClass="inline-banner" visible="false" managed="false"
          style="-fx-padding: 8 16 8 16;">
        <Label fx:id="bannerLabel" styleClass="banner-label" wrapText="true" HBox.hgrow="ALWAYS"/>
    </HBox>

    <!-- Game tile grid -->
    <VBox VBox.vgrow="ALWAYS" alignment="CENTER"
          style="-fx-padding: 24 40 16 40; -fx-spacing: 24;">

        <HBox spacing="24" alignment="CENTER">
            <!-- Tile 1 -->
            <VBox styleClass="game-tile" alignment="CENTER" spacing="6"
                  prefWidth="240" prefHeight="220">
                <Label text="⚙" style="-fx-font-size: 34px; -fx-text-fill: #B8A7E0;"/>
                <Label text="№ 1" styleClass="game-tile-number"/>
                <Label text="MIN COST" styleClass="game-tile-title"/>
                <Label text="Hungarian vs Branch &amp; Bound" styleClass="game-tile-desc" wrapText="true" alignment="CENTER"/>
                <HBox spacing="8" alignment="CENTER" style="-fx-padding: 6 0 0 0;">
                    <Button text="▶ PLAY" onAction="#openMinimumCost" styleClass="btn-primary"
                            style="-fx-font-size: 12px; -fx-padding: 6 14 6 14;"/>
                    <Button text="⧉ REC" onAction="#openGame1Records" styleClass="records-button"
                            style="-fx-font-size: 14px; -fx-padding: 5 10 5 10;"/>
                </HBox>
            </VBox>

            <!-- Tile 2 -->
            <VBox styleClass="game-tile" alignment="CENTER" spacing="6"
                  prefWidth="240" prefHeight="220">
                <Label text="🪜" style="-fx-font-size: 34px;"/>
                <Label text="№ 2" styleClass="game-tile-number"/>
                <Label text="SNAKE &amp; LADDER" styleClass="game-tile-title"/>
                <Label text="BFS vs Dynamic Programming" styleClass="game-tile-desc" wrapText="true" alignment="CENTER"/>
                <HBox spacing="8" alignment="CENTER" style="-fx-padding: 6 0 0 0;">
                    <Button text="▶ PLAY" onAction="#openSnakeLadder" styleClass="btn-primary"
                            style="-fx-font-size: 12px; -fx-padding: 6 14 6 14;"/>
                    <Button text="⧉ REC" onAction="#openGame2Records" styleClass="records-button"
                            style="-fx-font-size: 14px; -fx-padding: 5 10 5 10;"/>
                </HBox>
            </VBox>

            <!-- Tile 3 -->
            <VBox styleClass="game-tile" alignment="CENTER" spacing="6"
                  prefWidth="240" prefHeight="220">
                <Label text="🚦" style="-fx-font-size: 34px;"/>
                <Label text="№ 3" styleClass="game-tile-number"/>
                <Label text="TRAFFIC FLOW" styleClass="game-tile-title"/>
                <Label text="Ford-Fulkerson vs Edmonds-Karp" styleClass="game-tile-desc" wrapText="true" alignment="CENTER"/>
                <HBox spacing="8" alignment="CENTER" style="-fx-padding: 6 0 0 0;">
                    <Button text="▶ PLAY" onAction="#openTrafficSimulation" styleClass="btn-primary"
                            style="-fx-font-size: 12px; -fx-padding: 6 14 6 14;"/>
                    <Button text="⧉ REC" onAction="#openGame3Records" styleClass="records-button"
                            style="-fx-font-size: 14px; -fx-padding: 5 10 5 10;"/>
                </HBox>
            </VBox>
        </HBox>

        <HBox spacing="24" alignment="CENTER">
            <!-- Tile 4 -->
            <VBox styleClass="game-tile" alignment="CENTER" spacing="6"
                  prefWidth="240" prefHeight="220">
                <Label text="♞" style="-fx-font-size: 34px; -fx-text-fill: #FFE500;"/>
                <Label text="№ 4" styleClass="game-tile-number"/>
                <Label text="KNIGHT'S TOUR" styleClass="game-tile-title"/>
                <Label text="Warnsdorff's vs Backtracking" styleClass="game-tile-desc" wrapText="true" alignment="CENTER"/>
                <HBox spacing="8" alignment="CENTER" style="-fx-padding: 6 0 0 0;">
                    <Button text="▶ PLAY" onAction="#openKnightsTour" styleClass="btn-primary"
                            style="-fx-font-size: 12px; -fx-padding: 6 14 6 14;"/>
                    <Button text="⧉ REC" onAction="#openGame4Records" styleClass="records-button"
                            style="-fx-font-size: 14px; -fx-padding: 5 10 5 10;"/>
                </HBox>
            </VBox>

            <!-- Tile 5 -->
            <VBox styleClass="game-tile" alignment="CENTER" spacing="6"
                  prefWidth="240" prefHeight="220">
                <Label text="♛" style="-fx-font-size: 34px; -fx-text-fill: #FF2E88;"/>
                <Label text="№ 5" styleClass="game-tile-number"/>
                <Label text="SIXTEEN QUEENS" styleClass="game-tile-title"/>
                <Label text="Sequential vs Multi-Threaded solver" styleClass="game-tile-desc" wrapText="true" alignment="CENTER"/>
                <HBox spacing="8" alignment="CENTER" style="-fx-padding: 6 0 0 0;">
                    <Button text="▶ PLAY" onAction="#openSixteenQueens" styleClass="btn-primary"
                            style="-fx-font-size: 12px; -fx-padding: 6 14 6 14;"/>
                    <Button text="⧉ REC" onAction="#openGame5Records" styleClass="records-button"
                            style="-fx-font-size: 14px; -fx-padding: 5 10 5 10;"/>
                </HBox>
            </VBox>
        </HBox>

    </VBox>

    <!-- Footer -->
    <HBox alignment="CENTER" spacing="0"
          style="-fx-padding: 10 40 14 40; -fx-background-color: #160032;
                 -fx-border-width: 1 0 0 0; -fx-border-color: #FF2E8873;">
        <Label text="[1-5] PLAY  ·  [SHIFT+1-5] RECORDS  ·  [ESC] QUIT"
               styleClass="footer-text"/>
    </HBox>

</VBox>
