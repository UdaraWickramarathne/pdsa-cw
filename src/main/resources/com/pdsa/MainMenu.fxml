<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.pdsa.MainMenuController"
      alignment="CENTER" spacing="20"
      style="-fx-background-color: #1a1a2e; -fx-padding: 40;">

    <Text text="PDSA Coursework" style="-fx-fill: #e94560; -fx-font-size: 32; -fx-font-weight: bold;"/>
    <Text text="BSc (Hons) Computing 25.2 — Select a Game" style="-fx-fill: #a8a8b3; -fx-font-size: 14;"/>

    <VBox spacing="12" alignment="CENTER" style="-fx-padding: 20 0 0 0;">

        <HBox spacing="8" alignment="CENTER">
            <Button text="1.  Minimum Cost" onAction="#openMinimumCost"
                    prefWidth="232" prefHeight="50"
                    styleClass="menu-button"/>
            <Button text="Records" onAction="#openGame1Records"
                    prefWidth="80" prefHeight="50"
                    styleClass="records-button"/>
        </HBox>

        <HBox spacing="8" alignment="CENTER">
            <Button text="2.  Snake and Ladder" onAction="#openSnakeLadder"
                    prefWidth="232" prefHeight="50"
                    styleClass="menu-button"/>
            <Button text="Records" onAction="#openGame2Records"
                    prefWidth="80" prefHeight="50"
                    styleClass="records-button"/>
        </HBox>

        <HBox spacing="8" alignment="CENTER">
            <Button text="3.  Traffic Simulation" onAction="#openTrafficSimulation"
                    prefWidth="232" prefHeight="50"
                    styleClass="menu-button"/>
            <Button text="Records" onAction="#openGame3Records"
                    prefWidth="80" prefHeight="50"
                    styleClass="records-button"/>
        </HBox>

        <HBox spacing="8" alignment="CENTER">
            <Button text="4.  Knight's Tour" onAction="#openKnightsTour"
                    prefWidth="232" prefHeight="50"
                    styleClass="menu-button"/>
            <Button text="Records" onAction="#openGame4Records"
                    prefWidth="80" prefHeight="50"
                    styleClass="records-button"/>
        </HBox>

        <HBox spacing="8" alignment="CENTER">
            <Button text="5.  Sixteen Queens" onAction="#openSixteenQueens"
                    prefWidth="232" prefHeight="50"
                    styleClass="menu-button"/>
            <Button text="Records" onAction="#openGame5Records"
                    prefWidth="80" prefHeight="50"
                    styleClass="records-button"/>
        </HBox>

    </VBox>

    <Text text="Group Work — NIBM PDSA 2026" style="-fx-fill: #555577; -fx-font-size: 11;"/>
</VBox>
