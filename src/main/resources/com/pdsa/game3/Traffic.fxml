<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.canvas.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.chart.*?>

<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.pdsa.game3.ui.TrafficController">

    <VBox styleClass="game-root">

        <!-- Toolbar -->
        <HBox styleClass="game-toolbar">
            <Text text="🚦 TRAFFIC FLOW" styleClass="game-title-text"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="lblRoundBadge" text="ROUND —" styleClass="round-badge"/>
            <Region style="-fx-pref-width: 12;"/>
            <ToggleButton fx:id="btnHistory" text="⏶ HISTORY" styleClass="btn-history"
                          onAction="#toggleHistory"/>
        </HBox>

        <!-- Inline banner -->
        <HBox fx:id="bannerBox" styleClass="inline-banner" visible="false" managed="false">
            <Label fx:id="bannerLabel" styleClass="banner-label" wrapText="true" HBox.hgrow="ALWAYS"/>
        </HBox>

        <!-- Graph canvas -->
        <VBox styleClass="board-wrapper" style="-fx-margin: 12 16 4 16; -fx-padding: 6;">
            <Canvas fx:id="graphCanvas" width="960" height="420"/>
        </VBox>

        <!-- Legend -->
        <HBox spacing="16" alignment="CENTER_LEFT" style="-fx-padding: 4 16 4 16;">
            <Label text="●" style="-fx-text-fill: #39FF14; -fx-font-size: 14px;"/>
            <Label text="Source A" styleClass="ui-caption"/>
            <Label text="●" style="-fx-text-fill: #FF2E88; -fx-font-size: 14px;"/>
            <Label text="Sink T" styleClass="ui-caption"/>
            <Label text="━" style="-fx-text-fill: #6A5A9C; -fx-font-size: 14px;"/>
            <Label text="Edge" styleClass="ui-caption"/>
            <Label text="●" style="-fx-text-fill: #FFE500; -fx-font-size: 12px;"/>
            <Label text="Capacity (vehicles/min)" styleClass="ui-caption"/>
        </HBox>

        <!-- Algorithm timings -->
        <HBox spacing="16" style="-fx-padding: 4 16 8 16;">
            <Label fx:id="lblFF" text="Ford-Fulkerson: —" styleClass="label-cyan"
                   style="-fx-font-weight: bold;"/>
            <Label fx:id="lblEK" text="Edmonds-Karp: —" styleClass="label-amber"
                   style="-fx-font-weight: bold;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="lblRoundInfo" text="" styleClass="label-dim"/>
        </HBox>

        <!-- Not-started overlay — shown until first round -->
        <StackPane fx:id="startOverlay" style="-fx-padding: 8 16;">
            <Button text="▶ START FIRST ROUND" onAction="#startNewRound"
                    styleClass="btn-ghost" prefHeight="36"/>
        </StackPane>

        <!-- Player input — two separate cards -->
        <HBox spacing="12" style="-fx-padding: 4 16 8 16;" alignment="CENTER_LEFT">
            <!-- Guess card -->
            <VBox styleClass="neon-panel" spacing="6" HBox.hgrow="ALWAYS">
                <Label text="YOUR GUESS" styleClass="section-title"/>
                <HBox spacing="8" alignment="CENTER_LEFT">
                    <Label text="Name:" styleClass="label-dim"/>
                    <TextField fx:id="tfPlayerName" promptText="Enter your name" HBox.hgrow="ALWAYS"/>
                </HBox>
                <HBox spacing="8" alignment="CENTER_LEFT">
                    <Label text="Max flow:" styleClass="label-dim"/>
                    <TextField fx:id="tfAnswer" promptText="Enter number" prefWidth="100"/>
                    <Button fx:id="btnSubmit" text="⏎ SUBMIT" onAction="#submitAnswer"
                            styleClass="btn-secondary" prefHeight="32"
                            style="-fx-font-size: 11px; -fx-padding: 5 14;"/>
                </HBox>
                <Label fx:id="lblResult" text="" wrapText="true"
                       style="-fx-font-size: 14px; -fx-font-weight: bold;"/>
            </VBox>

            <!-- New round card -->
            <VBox styleClass="stat-card" spacing="6" alignment="CENTER">
                <Label text="NEW ROUND" styleClass="section-title"/>
                <Button text="▶ NEW ROUND" onAction="#startNewRound"
                        styleClass="btn-primary" prefHeight="36"/>
            </VBox>
        </HBox>

        <!-- Chart -->
        <VBox style="-fx-padding: 0 16 12 16;" spacing="4" VBox.vgrow="NEVER">
            <Label text="Algorithm Timing per Round (ms)" styleClass="label-dim"
                   style="-fx-font-weight: bold;"/>
            <BarChart fx:id="timeChart" prefHeight="180" animated="false"
                      styleClass="chart-dark">
                <xAxis><CategoryAxis label="Round"/></xAxis>
                <yAxis><NumberAxis label="Time (ms)"/></yAxis>
            </BarChart>
        </VBox>

    </VBox>

    <!-- Records drawer -->
    <VBox fx:id="recordsDrawer" styleClass="records-drawer"
          StackPane.alignment="CENTER_RIGHT" visible="false">
        <HBox styleClass="drawer-header" alignment="CENTER_LEFT" spacing="8">
            <Label text="RECORDS" styleClass="drawer-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="✕" styleClass="btn-ghost"
                    style="-fx-padding: 1 6 1 6; -fx-font-size: 11px;"
                    onAction="#closeDrawer"/>
        </HBox>
        <TabPane fx:id="recordsTabPane" VBox.vgrow="ALWAYS" tabClosingPolicy="UNAVAILABLE"/>
    </VBox>

</StackPane>
