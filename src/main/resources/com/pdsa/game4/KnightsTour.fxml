<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.canvas.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.chart.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.pdsa.game4.ui.KnightsTourController"
      style="-fx-background-color: #1a1a2e;">

    <!-- Main content: board + controls side by side -->
    <HBox spacing="16" style="-fx-padding: 16;" VBox.vgrow="ALWAYS">

        <!-- Left: chessboard -->
        <VBox spacing="8" minWidth="480">
            <Text text="Knight's Tour" style="-fx-fill: #e94560; -fx-font-size: 22; -fx-font-weight: bold;"/>
            <Label text="Click cells in the order the knight should visit them."
                   style="-fx-text-fill: #a8a8b3; -fx-font-size: 11;"/>
            <Canvas fx:id="boardCanvas" width="460" height="460"
                    onMouseClicked="#handleCanvasClick"
                    style="-fx-cursor: hand;"/>
        </VBox>

        <!-- Right: controls -->
        <VBox spacing="10" HBox.hgrow="ALWAYS">
            <Text text="Controls" style="-fx-fill: #4ecca3; -fx-font-size: 16; -fx-font-weight: bold;"/>

            <HBox spacing="12" alignment="CENTER_LEFT">
                <Label text="Board size:" style="-fx-text-fill: #a8a8b3;"/>
                <RadioButton fx:id="rb8x8"   text="8 × 8"  style="-fx-text-fill: #e0e0e0;"/>
                <RadioButton fx:id="rb16x16" text="16 × 16" style="-fx-text-fill: #e0e0e0;"/>
            </HBox>

            <Button fx:id="btnNewRound" text="New Round" onAction="#startNewRound"
                    prefWidth="160"
                    style="-fx-background-color: #e94560; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;"/>

            <Separator/>

            <Label fx:id="lblStart"        text="Start: —" style="-fx-text-fill: #a8a8b3;"/>
            <Label fx:id="lblWarnsdorff"   text="Warnsdorff: —" style="-fx-text-fill: #4ecca3;"/>
            <Label fx:id="lblBacktracking" text="Backtracking: —" style="-fx-text-fill: #f9a826;" wrapText="true"/>
            <Label fx:id="lblStatus"       text="" style="-fx-text-fill: #a8a8b3;" wrapText="true"/>

            <Separator/>

            <Label text="Your Name:" style="-fx-text-fill: #a8a8b3;"/>
            <TextField fx:id="tfPlayerName" promptText="Enter your name"
                       style="-fx-control-inner-background: #16213e; -fx-text-fill: #e0e0e0;"/>

            <HBox spacing="10">
                <Button fx:id="btnCheckTour" text="Check Tour" onAction="#checkTour"
                        disable="true" prefWidth="120"
                        style="-fx-background-color: #4ecca3; -fx-text-fill: #1a1a2e; -fx-font-weight: bold; -fx-cursor: hand;"/>
                <Button fx:id="btnShowSolution" text="Show Solution" onAction="#showSolution"
                        disable="true" prefWidth="130"
                        style="-fx-background-color: #555577; -fx-text-fill: white; -fx-cursor: hand;"/>
            </HBox>

            <Label fx:id="lblResult" text="" wrapText="true"
                   style="-fx-font-size: 13; -fx-font-weight: bold;"/>
        </VBox>
    </HBox>

    <!-- Algorithm timing chart -->
    <VBox style="-fx-padding: 0 16 12 16;" spacing="4">
        <Label text="Algorithm Timing per Round (ms)" style="-fx-text-fill: #a8a8b3; -fx-font-weight: bold;"/>
        <BarChart fx:id="timeChart" prefHeight="210" animated="false">
            <xAxis><CategoryAxis label="Round"/></xAxis>
            <yAxis><NumberAxis label="Time (ms)"/></yAxis>
        </BarChart>
    </VBox>
</VBox>
