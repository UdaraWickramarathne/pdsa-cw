<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.canvas.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.chart.*?>

<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.pdsa.game4.ui.KnightsTourController">

    <VBox styleClass="game-root">

        <!-- Toolbar -->
        <HBox styleClass="game-toolbar">
            <Text text="♞ KNIGHT'S TOUR" styleClass="game-title-text"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="lblRoundBadge" text="ROUND —" styleClass="round-badge"/>
            <Region style="-fx-pref-width: 12;"/>
            <ToggleButton fx:id="btnHistory" text="⏶ HISTORY" styleClass="btn-history"
                          onAction="#toggleHistory"/>
        </HBox>

        <!-- Inline banner -->
        <HBox fx:id="bannerBox" styleClass="inline-banner" visible="false" managed="false">
            <Label fx:id="bannerLabel" styleClass="banner-label" wrapText="true" HBox.hgrow="ALWAYS"/>
        </HBox>

        <!-- Board + controls split -->
        <HBox spacing="0" VBox.vgrow="ALWAYS">

            <!-- Board column -->
            <VBox spacing="8" style="-fx-padding: 12 8 12 16;" minWidth="620">
                <Label text="Start at the ♞ marker. Yellow = valid L-shape moves."
                       styleClass="ui-caption"/>
                <VBox styleClass="board-wrapper">
                    <Canvas fx:id="boardCanvas" width="590" height="590"
                            onMouseClicked="#handleCanvasClick"
                            style="-fx-cursor: hand;"/>
                </VBox>
            </VBox>

            <!-- Separator -->
            <Separator orientation="VERTICAL" style="-fx-padding: 0 4;"/>

            <!-- Controls column -->
            <VBox spacing="10" HBox.hgrow="ALWAYS" style="-fx-padding: 12 16 12 8;">

                <!-- Setup card -->
                <VBox styleClass="stat-card" spacing="8">
                    <Label text="SETUP" styleClass="section-title"/>
                    <HBox spacing="8" alignment="CENTER_LEFT">
                        <Label text="Board size:" styleClass="label-dim"/>
                        <ToggleButton fx:id="rb8x8"   text="8 × 8"   styleClass="pill-toggle pill-first"
                                      onAction="#onSizeToggle"/>
                        <ToggleButton fx:id="rb16x16" text="16 × 16" styleClass="pill-toggle pill-last"
                                      onAction="#onSizeToggle"/>
                    </HBox>
                    <Button fx:id="btnNewRound" text="▶ NEW ROUND" onAction="#startNewRound"
                            styleClass="btn-primary" prefWidth="160"/>
                </VBox>

                <!-- Timings card -->
                <VBox styleClass="stat-card" spacing="6">
                    <Label text="ALGORITHM TIMINGS" styleClass="section-title"/>
                    <Label fx:id="lblStart"        text="Start: —"        styleClass="label-dim"/>
                    <Label fx:id="lblWarnsdorff"   text="Warnsdorff: —"   styleClass="label-cyan"/>
                    <Label fx:id="lblBacktracking" text="Backtracking: —"  styleClass="label-amber" wrapText="true"/>
                    <Label fx:id="lblStatus"       text=""                 styleClass="label-dim" wrapText="true"/>
                </VBox>

                <!-- Verify card -->
                <VBox styleClass="neon-panel" spacing="8" VBox.vgrow="ALWAYS">
                    <Label text="VERIFY YOUR TOUR" styleClass="section-title"/>
                    <Label text="Your name:" styleClass="label-dim"/>
                    <TextField fx:id="tfPlayerName" promptText="Enter your name"/>
                    <HBox spacing="8">
                        <Button fx:id="btnCheckTour" text="✓ CHECK TOUR" onAction="#checkTour"
                                styleClass="btn-secondary" disable="true" prefWidth="130"/>
                        <Button fx:id="btnUndo" text="↶ UNDO" onAction="#undoLastClick"
                                styleClass="btn-ghost" disable="true" prefWidth="80"/>
                    </HBox>
                    <Button fx:id="btnShowSolution" text="◎ SHOW SOLUTION" onAction="#showSolution"
                            styleClass="btn-ghost" disable="true" prefWidth="210"/>
                    <Label fx:id="lblResult" text="" wrapText="true"
                           style="-fx-font-size: 13px; -fx-font-weight: bold;"/>
                </VBox>

            </VBox>
        </HBox>

        <!-- Chart -->
        <VBox style="-fx-padding: 0 16 12 16;" spacing="4" VBox.vgrow="NEVER">
            <Label text="Algorithm Timing per Round (ms)" styleClass="label-dim"
                   style="-fx-font-weight: bold;"/>
            <BarChart fx:id="timeChart" prefHeight="180" animated="false"
                      styleClass="chart-dark">
                <xAxis><CategoryAxis label="Round"/></xAxis>
                <yAxis><NumberAxis label="Time (ms)"/></yAxis>
            </BarChart>
        </VBox>

    </VBox>

    <!-- Records drawer -->
    <VBox fx:id="recordsDrawer" styleClass="records-drawer"
          StackPane.alignment="CENTER_RIGHT" visible="false">
        <HBox styleClass="drawer-header" alignment="CENTER_LEFT" spacing="8">
            <Label text="RECORDS" styleClass="drawer-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="✕" styleClass="btn-ghost"
                    style="-fx-padding: 1 6 1 6; -fx-font-size: 11px;"
                    onAction="#closeDrawer"/>
        </HBox>
        <TabPane fx:id="recordsTabPane" VBox.vgrow="ALWAYS" tabClosingPolicy="UNAVAILABLE"/>
    </VBox>

</StackPane>
