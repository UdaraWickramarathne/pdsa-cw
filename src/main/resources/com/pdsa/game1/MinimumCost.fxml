<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.pdsa.game1.ui.MinimumCostController"
      spacing="12" style="-fx-background-color: #1a1a2e; -fx-padding: 20;">

    <!-- Header -->
    <HBox alignment="CENTER_LEFT" spacing="12">
        <Text text="Minimum Cost Assignment" style="-fx-fill: #e94560; -fx-font-size: 22; -fx-font-weight: bold;"/>
    </HBox>

    <!-- Input row -->
    <HBox spacing="12" alignment="CENTER_LEFT">
        <Label text="Number of Tasks (50 – 100):" style="-fx-text-fill: #a8a8b3;"/>
        <TextField fx:id="tfN" promptText="e.g. 75" prefWidth="80"
                   style="-fx-control-inner-background: #16213e; -fx-text-fill: #e0e0e0;"/>
        <Button text="Random" onAction="#fillRandom"
                style="-fx-background-color: #555577; -fx-text-fill: white; -fx-cursor: hand;"/>
    </HBox>

    <!-- Status bar -->
    <HBox spacing="20" alignment="CENTER_LEFT">
        <Label fx:id="lblN" text="N = ?" style="-fx-text-fill: #a8a8b3;"/>
        <Label fx:id="lblRoundId" text="Round ID: —" style="-fx-text-fill: #a8a8b3;"/>
        <Label fx:id="lblStatus" text="" style="-fx-text-fill: #4ecca3; -fx-font-weight: bold;"/>
    </HBox>

    <!-- Results area -->
    <HBox spacing="16" VBox.vgrow="ALWAYS">
        <VBox spacing="6" HBox.hgrow="ALWAYS">
            <Label text="Hungarian Algorithm (O(N³))" style="-fx-text-fill: #4ecca3; -fx-font-weight: bold;"/>
            <TextArea fx:id="taHungarian" editable="false" wrapText="true" prefHeight="340"
                      style="-fx-control-inner-background: #16213e; -fx-text-fill: #e0e0e0; -fx-font-family: monospace;"/>
        </VBox>
        <VBox spacing="6" HBox.hgrow="ALWAYS">
            <Label text="Branch and Bound" style="-fx-text-fill: #f9a826; -fx-font-weight: bold;"/>
            <TextArea fx:id="taBranchBound" editable="false" wrapText="true" prefHeight="340"
                      style="-fx-control-inner-background: #16213e; -fx-text-fill: #e0e0e0; -fx-font-family: monospace;"/>
        </VBox>
    </HBox>

    <!-- Controls -->
    <HBox alignment="CENTER" spacing="20">
        <Button fx:id="btnNewRound" text="New Round" onAction="#startNewRound"
                prefWidth="160" prefHeight="38"
                style="-fx-background-color: #e94560; -fx-text-fill: white; -fx-font-weight: bold; -fx-border-radius: 5; -fx-background-radius: 5; -fx-cursor: hand;"/>
    </HBox>
</VBox>
